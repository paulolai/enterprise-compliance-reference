{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@executable-specs/shared": ["../shared/src"],
      "@executable-specs/shared/*": ["../shared/src/*"],
      "@executable-specs/shared/fixtures": ["../shared/fixtures"],
      "@executable-specs/shared/fixtures/*": ["../shared/fixtures/*"]
    }
  },
  "include": ["src/**/*", "test/**/*"]
}
